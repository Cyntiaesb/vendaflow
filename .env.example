# ===== INSTAGRAM ACCOUNTS =====
INSTAGRAM_USERNAME_1=sua_conta_1
INSTAGRAM_PASSWORD_1=sua_senha_1
INSTAGRAM_USERNAME_2=sua_conta_2
INSTAGRAM_PASSWORD_2=sua_senha_2

# ===== ANTHROPIC (Claude) =====
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXX

# ===== CALENDLY =====
CALENDLY_API_KEY=eyJhbGciOiXXXXXXX
CALENDLY_LINK=https://calendly.com/seu-usuario/30min

# ===== APOLLO.IO (Purchase Intent + Enrichment) =====
# Obtenha em: https://app.apollo.io/settings/integrations/api
APOLLO_API_KEY=your_apollo_api_key_here

# Keywords de intenção — o que seu cliente busca antes de comprar
# Exemplo para agência de marketing:
APOLLO_INTENT_KEYWORDS=marketing digital,agencia de marketing,aumentar vendas,gerar leads

# Localização alvo (deixe vazio para busca nacional)
APOLLO_LOCATION=São Paulo, BR

# Nível mínimo de intent: high | medium | low
APOLLO_INTENT_SCORE=high

# Quantos leads de intent buscar por dia
APOLLO_LEADS_PER_DAY=100

# ===== EVOLUTION API (WhatsApp) =====
# Instale: https://github.com/EvolutionAPI/evolution-api
# Docs: https://doc.evolution-api.com
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_api_key_here
EVOLUTION_INSTANCE=savegram

# Limite de msgs WhatsApp por dia (comece com 20-30 em instâncias novas)
WHATSAPP_MESSAGES_PER_DAY=40

# ===== CONFIGURAÇÕES GERAIS =====
MESSAGES_PER_DAY=80
DELAY_MIN=20
DELAY_MAX=60
TARGET_NICHE=restaurante
DB_PATH=savegram.db
DASHBOARD_PORT=5000

# Nome e nicho do negócio
BUSINESS_NAME=VendasFlow
BUSINESS_NICHE=automação de prospecção com IA

# ===== META ADS =====
# Gere em: https://developers.facebook.com → seu App → Token de Acesso
# Permissões necessárias: ads_management, ads_read, business_management
META_ACCESS_TOKEN=your_meta_access_token_here

# ID da conta de anúncios — encontre em business.facebook.com (sem "act_")
META_AD_ACCOUNT_ID=123456789

# ID do Pixel Meta (para Conversions API)
META_PIXEL_ID=987654321

# Versão da API (não altere sem necessidade)
META_API_VERSION=v19.0

# ===== GOOGLE ADS =====
# Guia: https://developers.google.com/google-ads/api/docs/first-call/overview
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_CUSTOMER_ID=123-456-7890
GOOGLE_ADS_ACCESS_TOKEN=your_oauth2_access_token

# ===== GOOGLE MAPS PLACES API (Prospecção local) =====
# Ative em: console.cloud.google.com → APIs → Places API
# A mesma chave pode ser usada para Maps + Places
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Segmento alvo para busca local (ex: restaurante, clínica, academia)
MAPS_TARGET_SEGMENT=restaurante

# Cidade alvo (ex: São Paulo, Rio de Janeiro, Curitiba)
MAPS_TARGET_CITY=São Paulo

# Máximo de empresas a prospectar por dia via Google Maps
MAPS_LEADS_PER_DAY=50

# ===== OTIMIZAÇÃO DE ANÚNCIOS =====
# CPA máximo aceitável em reais (ex: R$150 por agendamento)
ADS_MAX_CPA_BRL=150

# % de aumento de budget para anúncios com ótimo CPA
ADS_SCALE_BUDGET_PCT=20

# Gasto mínimo (R$) antes de avaliar o anúncio (evita pausar por falta de dados)
ADS_MIN_SPEND_TO_EVALUATE=30

# ===== EMAIL (SendGrid) =====
# Crie conta em: https://sendgrid.com (free até 100 emails/dia)
# Docs: https://docs.sendgrid.com/api-reference/mail-send/mail-send
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Endereço verificado no SendGrid (Settings → Sender Authentication)
EMAIL_FROM_ADDRESS=seu@email.com.br
EMAIL_FROM_NAME=Seu Nome

# Configure o webhook em: SendGrid → Settings → Mail Settings → Event Webhook
# URL: https://seu-servidor.com/webhook/email
# Eventos: open, bounce, unsubscribe, click

# ===== APIFY (Análise de Perfis Instagram) =====
# Crie conta em: https://apify.com
# Plano Free: 1.000 resultados/mês (~1.000 perfis analisados)
# Plano Starter ($49/mês): 10.000 resultados — recomendado para volume
APIFY_API_KEY=apify_api_xxxxxxxxxxxxxxxxxxxxxxxx

# ===== COMPLIANCE / SEGURANÇA =====
# Email para alertas críticos (bot caiu, conta bloqueada, etc.)
ALERT_EMAIL=seu@email.com.br

# Token de acesso ao dashboard (qualquer string segura, ex: uuid4)
# Enviar em: GET /api/stats?token=SEU_TOKEN ou header X-API-Token: SEU_TOKEN
DASHBOARD_API_TOKEN=gere-um-token-aqui-ex-uuid4

# Assinatura do webhook do Calendly (Account Settings → Webhooks)
CALENDLY_WEBHOOK_SECRET=seu_webhook_secret_aqui

# Proxy residencial por conta Instagram (opcional mas recomendado para múltiplas contas)
# Formato: http://usuario:senha@host:porta
INSTAGRAM_PROXY_SUA_CONTA_1=http://user:pass@proxy.host:port
INSTAGRAM_PROXY_SUA_CONTA_2=http://user:pass@proxy.host:port

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ===== WHATSAPP BUSINESS API OFICIAL (Meta Cloud API) =====
# Substitui completamente a Evolution API
# Guia completo: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started

# 1. Acesse: business.facebook.com → WhatsApp → Getting Started
# 2. Crie app Business em: developers.facebook.com
# 3. Adicione produto WhatsApp → copie os IDs abaixo

# ID do número de telefone registrado (ex: 123456789012345)
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id

# ID da conta WhatsApp Business (ex: 987654321098765)  
WHATSAPP_BUSINESS_ACCOUNT_ID=seu_waba_id

# App Secret (developers.facebook.com → seu App → Settings → Basic → App Secret)
# Usado para verificar assinatura dos webhooks
META_APP_SECRET=seu_app_secret

# Token personalizado para verificação do webhook (pode ser qualquer string)
# Coloque o mesmo valor em: developers.facebook.com → seu App → WhatsApp → Configuration → Webhook
META_WEBHOOK_VERIFY_TOKEN=savegram_webhook_2024_token_seguro

# META_ACCESS_TOKEN (já configurado acima) é reutilizado para WhatsApp
# Certifique-se que o System User tem permissão: whatsapp_business_messaging

# ── Setup de templates (execute UMA VEZ após configurar as chaves acima) ──
# python -m modules.whatsapp.templates
# python -m modules.whatsapp.templates --status  (verificar aprovação)
